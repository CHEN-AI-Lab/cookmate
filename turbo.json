{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "AUTH_SECRET",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "AUTH_GITHUB_ID",
        "AUTH_GITHUB_SECRET",
        "AUTH_ALIPAY_ID",
        "AUTH_ALIPAY_SECRET",
        "ALIPAY_PUBLIC_KEY",
        "AUTH_WECHAT_ID",
        "AUTH_WECHAT_SECRET",
        "AI_API_KEY",
        "AI_BASE_URL",
        "AI_MODEL",
        "RESEND_API_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_PRO_PRICE_ID",
        "STRIPE_FAMILY_PRICE_ID",
        "NEXT_PUBLIC_APP_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": []
    }
  }
}
