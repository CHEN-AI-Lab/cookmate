# Database
# 本地开发: DATABASE_URL="file:./dev.db"
# 生产 (Neon): DATABASE_URL="postgresql://user:***@ep-xxx.neon.tech/cookmate?sslmode=require"
DATABASE_URL="file:./dev.db"
DIRECT_URL=""

# NextAuth
AUTH_SECRET="change-me-to-a-random-string"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# 支付宝登录（可选，需要配 RSA2 密钥）
AUTH_ALIPAY_ID=""
AUTH_ALIPAY_PRIVATE_KEY=""
AUTH_ALIPAY_PUBLIC_KEY=""

# 微信登录（可选，需要微信开放平台 App）
AUTH_WECHAT_ID=""
AUTH_WECHAT_SECRET=""

# Email (for magic link login)
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@cookmate.ai"

# AI API（支持任意 OpenAI 兼容接口）
# 不设置 KEY 时使用 mock 演示数据（本地测试无需配）
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL=""

# Stripe（国外支付）
STRIPE_SECRET_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_FAMILY_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"