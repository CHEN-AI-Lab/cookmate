# Database (SQLite 本地开发 / PostgreSQL 生产推荐 Neon)
# 本地开发: DATABASE_URL="file:./dev.db"
# 生产 (Neon): DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/cookmate?sslmode=require"
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="change-me-to-a-random-string"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# 支付宝登录（可选，需要配 RSA2 密钥）
AUTH_ALIPAY_ID=""
AUTH_ALIPAY_SECRET=""
ALIPAY_PUBLIC_KEY=""

# 微信登录（可选，需要微信开放平台 App）
AUTH_WECHAT_ID=""
AUTH_WECHAT_SECRET=""

# Email (for magic link login)
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@cookmate.ai"

# AI API（支持任意 OpenAI 兼容接口）
# 例：AI_API_KEY="sk-xxx" AI_BASE_URL="https://api.deepseek.com/v1" AI_MODEL="deepseek-chat"
# 不设置 KEY 时使用 mock 演示数据（本地测试无需配）
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_FAMILY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# PayJS 国内支付（个人可用，支持支付宝/微信扫码）
# 注册 https://payjs.cn → 获取商户号和密钥
PAYJS_MCHID=""
PAYJS_KEY=""
PAYJS_NOTIFY_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"