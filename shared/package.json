{
  "name": "@cookmate/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, constants, validators, utils, API helpers, hooks, and i18n messages for CookMate",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./types": "./types/index.ts",
    "./constants": "./constants/index.ts",
    "./validators": "./validators/index.ts",
    "./utils": "./utils/index.ts",
    "./utils/grocery-categories": "./utils/grocery-categories.ts",
    "./api": "./api/index.ts",
    "./hooks": "./hooks/index.ts",
    "./messages": "./messages/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.0"
  }
}
