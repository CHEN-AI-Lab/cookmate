generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  phone          String?  @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  subscriptionTier String @default("FREE")
  stripeCustomerId String? @unique
  stripeSubscriptionId String?
  dietType       String?  @default("不限")
  cuisinePref    String?  @default("不限")
  servingSize    Int      @default(2)
  onboardingCompleted Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  pantryItems PantryItem[]
  mealPlans   MealPlan[]
  recipes     Recipe[]
  usageDaily  UsageDaily[]
  groceryItems GroceryItem[]
  paymentOrders PaymentOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PantryItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  category  String?
  quantity  String?
  expiredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Recipe {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  ingredients  String
  steps        String
  cookingTime  Int?
  calories     Int?
  cuisineType  String?
  difficulty   String?
  imageUrl     String?
  isGenerated  Boolean  @default(true)
  starred      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealSlots MealSlot[]

  @@unique([userId, title])
}

model MealPlan {
  id        String     @id @default(cuid())
  userId    String
  weekStart DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots     MealSlot[]
  @@unique([userId, weekStart])
}

model MealSlot {
  id         String   @id @default(cuid())
  mealPlanId String
  dayOfWeek  Int
  mealType   String
  recipeId   String?
  note       String?

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@unique([mealPlanId, dayOfWeek, mealType])
}

model GroceryItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([email, code])
}

model UsageDaily {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  recipeCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model PaymentOrder {
  id            String   @id @default(cuid())
  userId        String
  orderId       String   @unique           // CM 开头订单号
  channel       String                     // "wechat" | "alipay"
  amount        Int                        // 分
  payjsOrderId  String?                    // PayJS 订单号
  status        String   @default("PENDING") // PENDING | PAID | EXPIRED | CANCELLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}