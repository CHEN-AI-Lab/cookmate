generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  subscriptionTier String @default("FREE")
  stripeCustomerId String? @unique
  stripeSubscriptionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  pantryItems PantryItem[]
  mealPlans   MealPlan[]
  recipes     Recipe[]
  usageDaily  UsageDaily[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PantryItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  category  String?
  quantity  String?
  expiredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?  @db.Text
  ingredients  String   @db.Text
  steps        String   @db.Text
  cookingTime  Int?
  calories     Int?
  cuisineType  String?
  difficulty   String?
  imageUrl     String?
  isGenerated  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealSlots MealSlot[]
}

model MealPlan {
  id        String     @id @default(cuid())
  userId    String
  weekStart DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots     MealSlot[]
  @@unique([userId, weekStart])
}

model MealSlot {
  id         String   @id @default(cuid())
  mealPlanId String
  dayOfWeek  Int
  mealType   String
  recipeId   String?
  note       String?

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id])
}

model UsageDaily {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  recipeCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}