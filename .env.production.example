# Database（Neon PostgreSQL）
DATABASE_URL="postgresql://user:password@host.neon.tech/cookmate?sslmode=require"

# NextAuth
AUTH_SECRET="随机字符串，用 openssl rand -base64 32 生成"

# 社交登录（可选，需要申请）
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email 验证码发送（生产环境必须配置）
EMAIL_HOST="smtp.qq.com"
EMAIL_PORT="587"
EMAIL_USER="your@qq.com"
EMAIL_PASS="授权码"
EMAIL_FROM="CookMate <your@qq.com>"

# 阿里云/腾讯云短信（生产环境必须配置）
# 选一个即可，以下是阿里云示例
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SIGN_NAME="CookMate"
ALIYUN_TEMPLATE_CODE="SMS_123456789"

# AI API（必须配置，生成菜谱用）
AI_API_KEY="sk-xxx"
AI_BASE_URL="https://token.sensenova.cn/v1"
AI_MODEL="sensenova-6.7-flash-lite"

# Stripe 支付（国外用户）
# 注册 https://dashboard.stripe.com → 创建产品
STRIPE_SECRET_KEY="sk_live_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_PRO_PRICE_ID="price_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PayJS 支付（国内用户，支付宝/微信）
# 注册 https://payjs.cn → 获取商户号和密钥
PAYJS_MCHID=""
PAYJS_KEY=""
PAYJS_NOTIFY_URL="https://your-domain.com/api/payment/notify"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"